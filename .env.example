# ─────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env.local and fill in the real values.
# ─────────────────────────────────────────────────────────────────────

# The public URL of your site (used for sitemaps and canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ───────────────────────────────────────
# EMAIL CONFIGURATION (Contact Form)
# ───────────────────────────────────────
# We recommend using Resend.com for easy email integration.
# Get your API key from: https://resend.com/api-keys

# Your API Key for the email service
CONTACT_API_KEY=re_xxxxxxxxxxxxx

# The email address form submissions should come FROM
# (This must be a verified domain in your email service dashboard)
CONTACT_FROM_EMAIL=noreply@pawsandwhiskers.vet

# The email address where you want to RECEIVE the messages
CONTACT_TO_EMAIL=care@pawsandwhiskers.vet

# ───────────────────────────────────────
# MAPS CONFIGURATION (Optional)
# ───────────────────────────────────────
# Google Maps API Key for styled maps or advanced geocoding
# Leave blank to use default embed (which may show branding)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ───────────────────────────────────────
# BOOKING SYSTEM (Optional)
# ───────────────────────────────────────
# API Endpoint for your practice management software
BOOKING_API_ENDPOINT=

# API Key for the booking system
BOOKING_API_KEY=